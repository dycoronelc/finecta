# Copie a .env y ajuste
SECRET_KEY=cambie-esto-por-una-clave-larga-aleatoria

# --- Base de datos ---
# Prioridad: 1) DATABASE_URL o MYSQL_URL (no vacíos)  2) DB_HOST+DB_NAME+DB_USER+DB_PASSWORD  3) SQLite en backend/finecta_dev.db
#
# Railway (plugin MySQL): suele exponer MYSQL_URL=mysql://... — se mapea automáticamente a mysql+pymysql + charset.
# Si define variables sueltas, deje DATABASE_URL sin definir o vacío para que no pisen a SQLite por defecto.
#
# Opcion A: URL (mysql:// o mysql+pymysql://)
DATABASE_URL=
# MYSQL_URL=   # alternativa Railway; equivalente a DATABASE_URL para esta app

# Opcion B: variables separadas (recomendada si la clave tiene caracteres especiales)
DB_DIALECT=mysql+pymysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=finecta
DB_USER=finecta
DB_PASSWORD=cambie-esto
DB_CHARSET=utf8mb4

# Orígenes del front (JSON o lista separada por comas). En producción incluya la URL pública del SPA.
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ACCESS_TOKEN_EXPIRE_MINUTES=1440
