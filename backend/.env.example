# Copie a .env y ajuste
SECRET_KEY=cambie-esto-por-una-clave-larga-aleatoria
# Opcion A: URL completa
DATABASE_URL=
# Opcion B: variables separadas (recomendada si la clave tiene caracteres especiales como /)
DB_DIALECT=mysql+pymysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=finecta
DB_USER=finecta
DB_PASSWORD=cambie-esto
DB_CHARSET=utf8mb4
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
ACCESS_TOKEN_EXPIRE_MINUTES=1440
